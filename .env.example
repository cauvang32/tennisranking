# 🎾 Tennis Ranking System - Environment Configuration

# Database Configuration (PostgreSQL)
DB_NAME=tennis_ranking
DB_USER=tennis_user
DB_PASSWORD=your_secure_database_password_here
DB_HOST=localhost
DB_PORT=5432
DB_SSL_REJECT_UNAUTHORIZED=false  # Set to 'false' only for local dev
DB_SSL_CA=/path/to/ca-cert.pem   # Optional: custom CA certificate

#Redis Cache
REDIS_URL=redis://localhost:6379

# Admin Authentication (REQUIRED - no fallbacks for security)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_EMAIL=admin@yourdomain.com

# Security Secrets (REQUIRED - generate strong random values)
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
CSRF_SECRET=your_csrf_secret_at_least_32_characters_long
JWT_ACCESS_TOKEN_EXPIRY=15m      # Short-lived access tokens (15 minutes)
JWT_REFRESH_TOKEN_EXPIRY=7d      # Long-lived refresh tokens (7 days)

# Server Configuration
PORT=3001
NODE_ENV=production

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_API_MAX=100

# Disable rate limiting completely (supports both spellings)
DISABLE_RATE_LIMITING=false
# DISABLE_RATELIMITING=false

# Dynamic Rate Limiting (CPU/RAM pressure-based)
# Notes:
# - CPU% is estimated from 1-minute load average / CPU cores.
# - When CPU/RAM exceed thresholds, effective limits are multiplied by the scale.
RATE_LIMIT_DYNAMIC_ENABLED=false
RATE_LIMIT_DYNAMIC_SAMPLE_MS=5000

RATE_LIMIT_CPU_HIGH_PCT=80
RATE_LIMIT_CPU_CRITICAL_PCT=95
RATE_LIMIT_RAM_HIGH_PCT=85
RATE_LIMIT_RAM_CRITICAL_PCT=95

RATE_LIMIT_DYNAMIC_SCALE_HIGH=0.7
RATE_LIMIT_DYNAMIC_SCALE_CRITICAL=0.4
RATE_LIMIT_DYNAMIC_MIN_SCALE=0.2

# CORS Settings
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Security Notes:
# - All secrets are REQUIRED - no fallback values for security
# - Use strong, unique passwords and secrets (32+ characters)
# - Never commit the actual .env file to version control
# - Rotate secrets regularly
# - Use different secrets for dev/staging/prod environments
# - Generate secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Password Hashing (2026 security standard)
BCRYPT_ROUNDS=14

# Cache Configuration (resource-aware, no strict limits)
# CACHE_MAX_ENTRIES=0 means dynamic (based on system resources)
# Set a number like 5000 to enforce a hard limit
CACHE_MAX_ENTRIES=0
CACHE_MAX_MEMORY_PERCENT=15       # Max % of system RAM for cache
CACHE_MIN_FREE_MEMORY_MB=256      # Keep this much RAM free minimum
CACHE_CLEANUP_INTERVAL=60000      # Cleanup expired entries every 60s
CACHE_PRELOAD_INTERVAL=240000     # Refresh cache every 4 minutes

# Database SSL (for remote DB connections only)
# DB_SSL=false                    # Enable for remote DB
# DB_SSL_REJECT_UNAUTHORIZED=true # Validate certificates
# DB_SSL_CA=/path/to/ca-cert.pem  # Custom CA certificate