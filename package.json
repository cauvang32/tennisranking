{
  "name": "ranking",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "npm run build && npm run server",
    "dev-full": "concurrently \"npm run dev\" \"npm run server\"",
    "build:subpath": "BASE_PATH=/tennis/ vite build",
    "build:subdomain": "BASE_PATH=/ vite build",
    "deploy:production": "NODE_ENV=production npm run build && npm run server",
    "preview:subpath": "npm run build:subpath && vite preview",
    "deploy:subpath": "BASE_PATH=/tennis/ NODE_ENV=production npm run build && NODE_ENV=production npm run server",
    "deploy:subdomain": "BASE_PATH=/ NODE_ENV=production npm run build && NODE_ENV=production npm run server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:cors": "curl -H \"Origin: https://mydomain.com\" -I http://localhost:3001/api/auth/status",
    "health-check": "curl -I http://localhost:3001/health || echo 'Health check endpoint not available'"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "terser": "^5.46.0",
    "vite": "^7.2.7",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf": "^3.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "express-validator": "^7.3.1",
    "geoip-country": "^5.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.12.0",
    "pg-cursor": "^2.19.0",
    "pm2": "^6.0.14",
    "rate-limit-redis": "^4.3.1",
    "rotating-file-stream": "^3.2.7",
    "ua-parser-js": "^2.0.7",
    "winston": "^3.19.0",
    "write-excel-file": "^2.3.10"
  }
}
